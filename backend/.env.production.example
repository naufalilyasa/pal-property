APP_ENV=production
PORT=8080
APP_NAME=pal-property
API_DOMAIN=api.example.com

DB_HOST=postgres
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_NAME=pal_db
DB_PORT=5432
DB_SSL_MODE=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

ELASTIC_ADDRESS=http://elasticsearch:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_INDEX_LISTINGS=listings
ELASTIC_INDEX_CHAT_RETRIEVAL=chat-retrieval

CHAT_GEMINI_API_KEY=CHANGE_ME
CHAT_GEMINI_MODEL=gemini-2.5-flash-lite
CHAT_SESSION_TTL_SECONDS=900
CHAT_MAX_HISTORY_TURNS=10
CHAT_GEMINI_TIMEOUT_SECONDS=20
CHAT_RETRIEVAL_TIMEOUT_MS=1500
CHAT_MAX_RETRIEVAL_DOCS=5

CORS_ALLOWED_ORIGINS=https://app.example.com
RATE_LIMIT_MAX=100
RATE_LIMIT_EXP=60

OAUTH_CLIENT_ID=CHANGE_ME
OAUTH_CLIENT_SECRET=CHANGE_ME
OAUTH_CALLBACK_URL=https://api.example.com/auth/oauth/google/callback

JWT_PRIVATE_KEY_BASE64=CHANGE_ME
JWT_PUBLIC_KEY_BASE64=CHANGE_ME
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

OAUTH_TOKEN_ENCRYPTION_KEY=CHANGE_ME

CLOUDINARY_ENABLED=true
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

WILAYAH_DATA_PATH=/app/db/wilayah.sql
