{
    "info": {
        "_postman_id": "eb0a0614-747d-419b-b467-36e6def09e0a",
        "name": "PAL Property API",
        "description": "Collection of API endpoints for the PAL Property Backend. Covers Authentication, Categories, Listing CRUD, and Cloudinary-backed listing image management.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Authentication",
            "description": "Endpoints governing user authentication and session management.",
            "item": [
                {
                    "name": "1. Begin OAuth Login (Google)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/auth/oauth/google",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "oauth", "google"]
                        },
                        "description": "Redirects the user to the Google OAuth consent screen. Open this in your browser rather than Postman because it requires user interaction."
                    },
                    "response": []
                },
                {
                    "name": "2. OAuth Callback",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/auth/oauth/google/callback?state=xyz&code=abc",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "oauth", "google", "callback"],
                            "query": [
                                {
                                    "key": "state",
                                    "value": "xyz",
                                    "description": "OAuth state parameter"
                                },
                                {
                                    "key": "code",
                                    "value": "abc",
                                    "description": "OAuth authorization code"
                                }
                            ]
                        },
                        "description": "Google redirects back to this endpoint after the user consents. Returns HTTP-only cookies (access_token and refresh_token)."
                    },
                    "response": []
                },
                {
                    "name": "3. Get Profile (Me)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/auth/me",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "me"]
                        },
                        "description": "Fetches the current user's profile. Requires a valid access_token HTTP-only cookie."
                    },
                    "response": []
                },
                {
                    "name": "4. Refresh Token",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/auth/refresh",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "refresh"]
                        },
                        "description": "Rotates the access and refresh tokens. Requires a valid refresh_token HTTP-only cookie."
                    },
                    "response": []
                },
                {
                    "name": "5. Logout",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/auth/logout",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "logout"]
                        },
                        "description": "Logs the user out by invalidating the refresh session in Redis and clearing both HTTP-only cookies."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Categories",
            "description": "Category management. GET endpoints are public. POST/PUT/DELETE require admin access_token cookie.",
            "item": [
                {
                    "name": "1. List All Categories (Public)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/categories",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "categories"]
                        },
                        "description": "Returns all root categories with their children nested. Public endpoint — no auth required."
                    },
                    "response": []
                },
                {
                    "name": "2. Get Category by Slug (Public)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/categories/{{categorySlug}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "categories", "{{categorySlug}}"]
                        },
                        "description": "Fetch a single category by slug, including its parent (for breadcrumbs) and children. Returns 404 if not found."
                    },
                    "response": []
                },
                {
                    "name": "3. Create Category (Admin)",
                    "request": {
                        "method": "POST",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Kondominium\",\n  \"parent_id\": \"11111111-0000-7000-8000-000000000001\",\n  \"icon_url\": null\n}",
                            "options": {"raw": {"language": "json"}}
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/categories/",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "categories", ""]
                        },
                        "description": "Create a new category. Requires admin access_token cookie. Slug is auto-generated from name. parent_id is optional (null = root category)."
                    },
                    "response": []
                },
                {
                    "name": "4. Update Category (Admin)",
                    "request": {
                        "method": "PUT",
                        "header": [{"key": "Content-Type", "value": "application/json"}],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Kondominium Mewah\"\n}",
                            "options": {"raw": {"language": "json"}}
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "categories", "{{categoryId}}"]
                        },
                        "description": "Update a category name and/or icon_url. Slug is locked after creation and cannot be changed. Requires admin cookie."
                    },
                    "response": []
                },
                {
                    "name": "5. Delete Category (Admin)",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "categories", "{{categoryId}}"]
                        },
                        "description": "Hard-delete a category. Blocked (409 Conflict) if category has children or is referenced by active listings. Requires admin cookie."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Listings",
            "description": "CRUD endpoints for property listings. Create/Update/Delete require a valid access_token cookie. List and Get are public.",
            "item": [
                {
                    "name": "1. List Listings (Public)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/listings?page=1&limit=10",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings"],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1",
                                    "description": "Page number (default: 1)"
                                },
                                {
                                    "key": "limit",
                                    "value": "10",
                                    "description": "Items per page (default: 10, max: 100)"
                                },
                                {
                                    "key": "status",
                                    "value": "active",
                                    "description": "Filter by public-safe status: active | sold",
                                    "disabled": true
                                },
                                {
                                    "key": "transaction_type",
                                    "value": "sale",
                                    "description": "Filter by transaction type: sale | rent",
                                    "disabled": true
                                },
                                {
                                    "key": "location_province",
                                    "value": "Jawa Barat",
                                    "description": "Filter by province name (case-insensitive partial match)",
                                    "disabled": true
                                },
                                {
                                    "key": "location_city",
                                    "value": "Jakarta",
                                    "description": "Canonical city filter name (legacy alias `city` is still accepted for compatibility)",
                                    "disabled": true
                                },
                                {
                                    "key": "category_id",
                                    "value": "{{categoryId}}",
                                    "description": "Filter by category UUID",
                                    "disabled": true
                                },
                                {
                                    "key": "price_min",
                                    "value": "500000000",
                                    "description": "Minimum price in IDR (int64)",
                                    "disabled": true
                                },
                                {
                                    "key": "price_max",
                                    "value": "2000000000",
                                    "description": "Maximum price in IDR (int64)",
                                    "disabled": true
                                },
                                {
                                    "key": "bedroom_count",
                                    "value": "3",
                                    "description": "Minimum bedroom count",
                                    "disabled": true
                                },
                                {
                                    "key": "bathroom_count",
                                    "value": "2",
                                    "description": "Minimum bathroom count",
                                    "disabled": true
                                },
                                {
                                    "key": "land_area_min",
                                    "value": "90",
                                    "description": "Minimum land area in square meters",
                                    "disabled": true
                                },
                                {
                                    "key": "building_area_min",
                                    "value": "75",
                                    "description": "Minimum building area in square meters",
                                    "disabled": true
                                },
                                {
                                    "key": "certificate_type",
                                    "value": "SHM",
                                    "description": "Filter by certificate type",
                                    "disabled": true
                                },
                                {
                                    "key": "condition",
                                    "value": "new",
                                    "description": "Filter by property condition",
                                    "disabled": true
                                },
                                {
                                    "key": "furnishing",
                                    "value": "semi",
                                    "description": "Filter by furnishing level",
                                    "disabled": true
                                }
                            ]
                        },
                        "description": "Returns a paginated list of listings. Public endpoints only expose public-safe statuses (`active`, `sold`). Supports filtering by transaction type, province/city, category_id, price range, selected typed property fields, and legacy-compatible listing metadata. Public endpoint — no auth required."
                    },
                    "response": []
                },
                {
                    "name": "2. Get Listing by ID (Public)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/{{listingId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", "{{listingId}}"]
                        },
                        "description": "Fetch a single public-safe listing by its UUID. Also increments the view_count asynchronously. Returns 404 if not found or if the listing is not public-safe."
                    },
                    "response": []
                },
                {
                    "name": "3. Get Listing by Slug (Public)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/slug/{{listingSlug}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", "slug", "{{listingSlug}}"]
                        },
                        "description": "Fetch a single public-safe listing by its URL-friendly slug. Also increments the view_count asynchronously. Returns 404 if not found or if the listing is not public-safe."
                    },
                    "response": []
                },
                {
                    "name": "4. Create Listing (Auth)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Rumah Minimalis 3 Kamar di Depok\",\n  \"description\": \"Rumah dengan desain modern minimalis, 3 kamar tidur, 2 kamar mandi, dekat tol.\",\n  \"transaction_type\": \"sale\",\n  \"price\": 850000000,\n  \"currency\": \"IDR\",\n  \"is_negotiable\": true,\n  \"special_offers\": [\"Promo\"],\n  \"status\": \"draft\",\n  \"location_province\": \"Jawa Barat\",\n  \"location_city\": \"Depok\",\n  \"location_district\": \"Beji\",\n  \"address_detail\": \"Jl. Margonda Raya No. 123\",\n  \"latitude\": -6.394,\n  \"longitude\": 106.822,\n  \"bedroom_count\": 3,\n  \"bathroom_count\": 2,\n  \"floor_count\": 2,\n  \"carport_capacity\": 1,\n  \"land_area_sqm\": 120,\n  \"building_area_sqm\": 90,\n  \"certificate_type\": \"SHM\",\n  \"condition\": \"new\",\n  \"furnishing\": \"semi\",\n  \"electrical_power_va\": 2200,\n  \"facing_direction\": \"east\",\n  \"year_built\": 2021,\n  \"facilities\": [\"AC\", \"CCTV\"],\n  \"category_id\": null,\n  \"specifications\": {\n    \"bedrooms\": 3,\n    \"bathrooms\": 2,\n    \"land_area_sqm\": 120,\n    \"building_area_sqm\": 90\n  }\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", ""]
                        },
                        "description": "Create a new property listing. Requires access_token cookie. Slug is auto-generated from the title. Price is in IDR (int64, must be > 0). Status now supports `active`, `inactive`, `sold`, `draft`, and `archived`. New typed property fields are accepted, while `specifications` remains temporarily for compatibility during the rollout."
                    },
                    "response": []
                },
                {
                    "name": "5. Update Listing (Auth — Owner or Admin)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"title\": \"Rumah Minimalis 3 Kamar di Depok - Updated\",\n  \"transaction_type\": \"rent\",\n  \"price\": 900000000,\n  \"status\": \"inactive\",\n  \"location_province\": \"Jawa Barat\",\n  \"bedroom_count\": 4,\n  \"bathroom_count\": 3,\n  \"land_area_sqm\": 135,\n  \"building_area_sqm\": 105,\n  \"special_offers\": [\"Turun_Harga\"],\n  \"facilities\": [\"AC\", \"Water_Heater\"],\n  \"specifications\": {\n    \"bedrooms\": 4,\n    \"bathrooms\": 3,\n    \"land_area_sqm\": 135,\n    \"building_area_sqm\": 105\n  }\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/{{listingId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", "{{listingId}}"]
                        },
                        "description": "Partially update a listing. Only provided fields are updated (PATCH semantics despite PUT method). Only the listing owner or an admin can update. Typed property fields are now supported; `specifications` is still accepted and regenerated for compatibility during the rollout. Returns 403 Forbidden for non-owners."
                    },
                    "response": []
                },
                {
                    "name": "6. Delete Listing (Auth — Owner or Admin)",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/{{listingId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", "{{listingId}}"]
                        },
                        "description": "Soft-delete a listing (sets deleted_at). Only the listing owner or an admin can delete. Returns 403 Forbidden for non-owners."
                    },
                    "response": []
                },
                {
                    "name": "7. My Listings (Auth)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/auth/me/listings?page=1&limit=10",
                            "host": ["{{baseUrl}}"],
                            "path": ["auth", "me", "listings"],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "1"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                },
                                {
                                    "key": "status",
                                    "value": "active",
                                    "disabled": true
                                }
                            ]
                        },
                        "description": "Returns a paginated list of listings belonging to the currently authenticated user. Seller-owned views can include non-public statuses such as `draft` and `archived`. Requires access_token cookie."
                    },
                    "response": []
                },
                {
                    "name": "8. Upload Listing Image (Auth — Owner or Admin)",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "file",
                                    "type": "file",
                                    "src": "",
                                    "description": "Image file field name must be `file`. Accepts typical image extensions/content types and stores metadata from Cloudinary in the returned `images` array."
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/{{listingId}}/images",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", "{{listingId}}", "images"]
                        },
                        "description": "Upload one image to a listing. Requires access_token cookie and listing ownership (admin bypasses ownership). Response returns the full listing projection with ordered `images` including Cloudinary delivery URL, dimensions, bytes, format, original_filename, primary flag, and sort_order."
                    },
                    "response": []
                },
                {
                    "name": "9. Delete Listing Image (Auth — Owner or Admin)",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/{{listingId}}/images/{{listingImageId}}",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", "{{listingId}}", "images", "{{listingImageId}}"]
                        },
                        "description": "Soft-delete one active listing image and remove its Cloudinary asset. If the deleted image was primary, the next ordered image becomes primary automatically. Returns the full listing projection with the updated `images` array."
                    },
                    "response": []
                },
                {
                    "name": "10. Set Primary Listing Image (Auth — Owner or Admin)",
                    "request": {
                        "method": "PATCH",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/{{listingId}}/images/{{listingImageId}}/primary",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", "{{listingId}}", "images", "{{listingImageId}}", "primary"]
                        },
                        "description": "Patch the selected active image into the primary slot without changing the current sort order. Requires access_token cookie plus ownership (admin bypass). Returns the full listing projection so you can verify `images[].is_primary`."
                    },
                    "response": []
                },
                {
                    "name": "11. Reorder Listing Images (Auth — Owner or Admin)",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"ordered_image_ids\": [\n    \"{{listingImageId}}\",\n    \"11111111-0000-7000-8000-000000000002\",\n    \"11111111-0000-7000-8000-000000000003\"\n  ]\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/listings/{{listingId}}/images/reorder",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "listings", "{{listingId}}", "images", "reorder"]
                        },
                        "description": "Patch the active image ordering for a listing. `ordered_image_ids` must contain every active image ID exactly once. Requires access_token cookie plus ownership (admin bypass). Response returns the full listing projection with normalized `sort_order` values starting at 0."
                    },
                    "response": []
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8080",
            "type": "string"
        },
        {
            "key": "listingId",
            "value": "",
            "type": "string",
            "description": "UUID of the listing — copy from Create response"
        },
        {
            "key": "listingSlug",
            "value": "",
            "type": "string",
            "description": "Slug of the listing — copy from Create response"
        },
        {
            "key": "listingImageId",
            "value": "",
            "type": "string",
            "description": "UUID of a listing image — copy from any listing response `images[].id` value"
        },
        {
            "key": "categoryId",
            "value": "",
            "type": "string",
            "description": "UUID of the category — copy from Create Category or Get Category responses"
        },
        {
            "key": "categorySlug",
            "value": "",
            "type": "string",
            "description": "Slug of a category — e.g. rumah, apartemen"
        }
    ]
}
