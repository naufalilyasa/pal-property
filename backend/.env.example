# App Config
APP_ENV=development
PORT=8080
APP_NAME=pal-property

# Database
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pal_db
DB_PORT=5432
DB_SSL_MODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Search indexing (modular monolith)
# Elasticsearch endpoint and optional basic auth for search projections
ELASTIC_ADDRESS=http://localhost:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_INDEX_LISTINGS=listings
ELASTIC_INDEX_CHAT_RETRIEVAL=chat-retrieval

# Chatbot (Gemini)
CHAT_GEMINI_API_KEY=
CHAT_GEMINI_MODEL=gemini-2.5-flash-lite
CHAT_SESSION_TTL_SECONDS=900
CHAT_MAX_HISTORY_TURNS=10
CHAT_GEMINI_TIMEOUT_SECONDS=20
CHAT_RETRIEVAL_TIMEOUT_MS=1500
CHAT_MAX_RETRIEVAL_DOCS=5

# Security & Middleware
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_EXP=60

# Google OAuth2
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:8080/auth/oauth/google/callback

# JWT Auth (base64-encoded PEM values)
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# AES-256 encryption key for OAuth provider tokens (base64-encoded 32 bytes)
# Generate: openssl rand -base64 32
OAUTH_TOKEN_ENCRYPTION_KEY=

# Cloudinary
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
