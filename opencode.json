{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ]
    },
    "go": {
      "command": ["gopls", "serve"],
      "extensions": [".go"]
    },
    "yaml-ls": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    }
  },
  "formatter": {
    "biome": {
      "disabled": false,
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".html", ".css"]
    },
    "gofmt": {
      "disabled": false,
      "extensions": [".go"]
    }
  }
}
